# =============================================================
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# The real .env is git-ignored so your secrets never get committed.
# =============================================================

# --- Server ---
PORT=4000

# --- MySQL / MariaDB connection ---
# These must match the database you created with db/schema.sql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=nv_elon

# --- Auth ---
# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change_me_to_a_long_random_string
# How long a login token stays valid (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# --- Payments ---
# TEST placeholders below let everything run with fake data. Replace with
# the real values from your Payme/Click merchant cabinets when you have them.
# Full instructions: PAYME_CLICK_SETUP.md
PAYME_MERCHANT_ID=test_merchant
PAYME_KEY=test_payme_key_123
PAYME_ACCOUNT_FIELD=order_id
PAYME_CHECKOUT_URL=https://checkout.paycom.uz

CLICK_SERVICE_ID=12345
CLICK_MERCHANT_ID=67890
CLICK_SECRET_KEY=test_click_secret_456
CLICK_CHECKOUT_URL=https://my.click.uz/services/pay
